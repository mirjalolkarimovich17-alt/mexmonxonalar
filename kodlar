<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>[HOTEL NAME] — Experience Luxury and Comfort</title>
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Inter+Tight:wght@400;500;600;700;800&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
<style>
  *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
  :root{
    --bg:linear-gradient(180deg,#e8eef7 0%,#dbe5f1 100%);
    --navy:#0e2a4d;
    --navy-2:#16385f;
    --primary:#1e4a8a;
    --text:#0e2a4d;
    --muted:#5b6b80;
    --card:#ffffff;
    --soft:#eef3fa;
  }
  html,body{background:var(--bg);color:var(--text);font-family:"Inter Tight","Inter",system-ui,sans-serif;-webkit-font-smoothing:antialiased}
  img{max-width:100%;display:block}
  a{color:inherit;text-decoration:none}
  .container{max-width:1240px;margin:0 auto;padding:0 24px}

  /* NAV */
  .nav-wrap{position:sticky;top:16px;z-index:50;padding:16px 24px 0}
  .nav{max-width:1240px;margin:0 auto;background:#fff;border-radius:16px;padding:14px 22px;display:flex;align-items:center;justify-content:space-between;box-shadow:0 8px 24px rgba(14,42,77,.06)}
  .brand{font-weight:700;letter-spacing:.02em;color:var(--navy)}
  .nav-right{display:flex;gap:10px;align-items:center}
  .btn{display:inline-flex;align-items:center;justify-content:center;border-radius:10px;padding:10px 18px;font-weight:600;font-size:14px;border:1px solid transparent;cursor:pointer;transition:.2s}
  .btn-primary{background:var(--primary);color:#fff}
  .btn-primary:hover{background:#173f78}
  .btn-outline{background:#fff;color:var(--navy);border-color:#e3e8ef}
  .btn-icon{width:42px;height:42px;border-radius:10px;background:var(--primary);color:#fff;display:inline-flex;align-items:center;justify-content:center}
  .btn-icon span{display:block;width:18px;height:2px;background:#fff;position:relative}
  .btn-icon span::before,.btn-icon span::after{content:"";position:absolute;left:0;width:18px;height:2px;background:#fff}
  .btn-icon span::before{top:-6px}.btn-icon span::after{top:6px}

  /* HERO */
  .hero{padding:80px 0 40px;text-align:center}
  .pill{display:inline-block;background:#fff;border-radius:999px;padding:8px 16px;font-size:13px;color:var(--navy);box-shadow:0 4px 14px rgba(14,42,77,.05);margin-bottom:24px}
  .hero h1{font-size:clamp(40px,7vw,96px);line-height:1.02;font-weight:700;color:var(--navy);letter-spacing:-.02em}
  .hero p{max-width:640px;margin:22px auto 0;color:var(--muted);font-size:17px;line-height:1.5}
  .hero-ctas{display:flex;gap:12px;justify-content:center;margin-top:28px}
  .fan{position:relative;height:520px;margin:60px auto 0;max-width:1100px}
  .fan .card{position:absolute;top:50%;left:50%;width:230px;height:320px;background:#fff;padding:10px;border-radius:6px;box-shadow:0 18px 40px rgba(14,42,77,.18);overflow:hidden;transform-origin:50% 100%}
  .fan .card img{width:100%;height:100%;object-fit:cover;border-radius:4px}
  .fan .c1{transform:translate(-50%,-50%) rotate(-18deg) translateY(-10px) translateX(-440px)}
  .fan .c2{transform:translate(-50%,-50%) rotate(-9deg) translateX(-220px)}
  .fan .c3{transform:translate(-50%,-50%) rotate(0deg)}
  .fan .c4{transform:translate(-50%,-50%) rotate(9deg) translateX(220px)}
  .fan .c5{transform:translate(-50%,-50%) rotate(18deg) translateY(-10px) translateX(440px)}
  @media(max-width:900px){.fan{height:380px}.fan .card{width:150px;height:210px}.fan .c1{transform:translate(-50%,-50%) rotate(-18deg) translateX(-260px)}.fan .c2{transform:translate(-50%,-50%) rotate(-9deg) translateX(-130px)}.fan .c4{transform:translate(-50%,-50%) rotate(9deg) translateX(130px)}.fan .c5{transform:translate(-50%,-50%) rotate(18deg) translateX(260px)}}

  /* SECTIONS */
  section.block{padding:90px 0}
  .eyebrow{color:var(--primary);font-weight:600;font-size:14px;letter-spacing:.04em;margin-bottom:14px}
  .h2{font-size:clamp(34px,5vw,56px);line-height:1.05;font-weight:700;color:var(--navy);letter-spacing:-.02em}
  .lead{color:var(--muted);font-size:17px;line-height:1.6;max-width:560px}

  .two-col{display:grid;grid-template-columns:1fr 1fr;gap:60px;align-items:center}
  @media(max-width:820px){.two-col{grid-template-columns:1fr}}

  /* SERVICES */
  .services-head{display:grid;grid-template-columns:1fr 1fr;gap:40px;align-items:end;margin-bottom:40px}
  @media(max-width:820px){.services-head{grid-template-columns:1fr}}
  .grid-3{display:grid;grid-template-columns:repeat(3,1fr);gap:24px}
  @media(max-width:900px){.grid-3{grid-template-columns:1fr}}
  .service{background:#fff;border-radius:20px;overflow:hidden;box-shadow:0 8px 28px rgba(14,42,77,.06)}
  .service .img{aspect-ratio:4/3;overflow:hidden}
  .service .img img{width:100%;height:100%;object-fit:cover}
  .service .body{padding:22px}
  .service h3{font-size:22px;color:var(--navy);margin-bottom:8px}
  .service p{color:var(--muted);font-size:15px;line-height:1.5}

  /* ROOMS */
  .rooms-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:24px}
  @media(max-width:900px){.rooms-grid{grid-template-columns:1fr 1fr}}
  @media(max-width:600px){.rooms-grid{grid-template-columns:1fr}}
  .room{position:relative;border-radius:20px;overflow:hidden;aspect-ratio:4/5;box-shadow:0 10px 30px rgba(14,42,77,.1)}
  .room img{width:100%;height:100%;object-fit:cover;transition:.4s}
  .room:hover img{transform:scale(1.05)}
  .room .label{position:absolute;left:18px;right:18px;bottom:18px;background:rgba(255,255,255,.92);backdrop-filter:blur(6px);padding:14px 16px;border-radius:12px}
  .room .label strong{display:block;color:var(--navy);font-size:17px;margin-bottom:2px}
  .room .label span{color:var(--muted);font-size:14px}

  /* STATS */
  .stats{background:var(--navy);color:#fff;border-radius:28px;padding:60px 40px;display:grid;grid-template-columns:1fr 1fr 1fr 1fr;gap:24px;text-align:center}
  @media(max-width:820px){.stats{grid-template-columns:1fr 1fr}}
  .stat .num{font-size:54px;font-weight:700;letter-spacing:-.02em}
  .stat .lbl{color:#a8b8cf;margin-top:6px;font-size:15px}

  /* TESTIMONIALS */
  .testimonials{display:grid;grid-template-columns:repeat(3,1fr);gap:24px}
  @media(max-width:900px){.testimonials{grid-template-columns:1fr 1fr}}
  @media(max-width:600px){.testimonials{grid-template-columns:1fr}}
  .testimonial{background:#fff;border-radius:20px;padding:26px;box-shadow:0 8px 24px rgba(14,42,77,.06);display:flex;flex-direction:column;gap:20px}
  .testimonial p{color:var(--navy);font-size:16px;line-height:1.55}
  .who{display:flex;align-items:center;gap:12px;margin-top:auto}
  .who img{width:44px;height:44px;border-radius:50%;object-fit:cover}
  .who strong{display:block;color:var(--navy);font-size:15px}
  .who span{color:var(--muted);font-size:13px}

  /* FAQ */
  .faq{background:#fff;border-radius:20px;padding:10px 26px;box-shadow:0 8px 24px rgba(14,42,77,.06)}
  .faq details{padding:22px 0;border-bottom:1px solid #eef2f7}
  .faq details:last-child{border-bottom:none}
  .faq summary{cursor:pointer;list-style:none;display:flex;justify-content:space-between;align-items:center;font-size:18px;color:var(--navy);font-weight:600}
  .faq summary::-webkit-details-marker{display:none}
  .faq summary::after{content:"+";font-size:24px;color:var(--primary);font-weight:400}
  .faq details[open] summary::after{content:"–"}
  .faq .ans{color:var(--muted);margin-top:10px;line-height:1.6}
  .tabs{display:inline-flex;background:var(--soft);border-radius:10px;padding:4px;margin-bottom:24px}
  .tabs button{border:none;background:transparent;padding:8px 18px;border-radius:8px;font-weight:600;color:var(--muted);cursor:pointer}
  .tabs button.active{background:#fff;color:var(--navy);box-shadow:0 2px 6px rgba(14,42,77,.06)}

  /* CTA */
  .cta{background:var(--navy);color:#fff;border-radius:28px;padding:80px 40px;text-align:center}
  .cta h2{font-size:clamp(32px,5vw,52px);line-height:1.1;max-width:820px;margin:0 auto 28px;font-weight:700}

  footer{padding:40px 0;text-align:center;color:var(--muted);font-size:14px}
</style>
</head>
<body>

