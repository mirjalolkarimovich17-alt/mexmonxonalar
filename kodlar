<script>
  document.querySelectorAll('.tabs button').forEach(b=>{
    b.addEventListener('click',()=>{
      b.parentElement.querySelectorAll('button').forEach(x=>x.classList.remove('active'));
      b.classList.add('active');
    });
  });
</script>
